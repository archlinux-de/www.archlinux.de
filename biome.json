{
    "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
    "files": {
        "includes": ["src/**", "*.ts", "*.json"]
    },
    "formatter": {
        "indentStyle": "space",
        "indentWidth": 4
    },
    "linter": {
        "rules": {
            "preset": "recommended",
            "style": {
                "useBlockStatements": "error"
            }
        }
    }
}
